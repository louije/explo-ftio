  "components": {
    "securitySchemes": {
      "authentification_individu": {
        "type": "oauth2",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://authentification-candidat.francetravail.fr/connexion/oauth2/authorize?realm=/individu",
            "scopes": {
              "api_peconnect-metiersrecherchesv1": "Obligatoire",
              "cpmetiers": "Obligatoire"
            },
            "tokenUrl": "https://authentification-candidat.francetravail.fr/connexion/oauth2/access_token?realm=/individu"
          }
        }
      }
    },
    "schemas": {
      "MetierRecherche": {
        "type": "object",
        "properties": {
          "appellation": {
            "$ref": "#/components/schemas/Appellation"
          },
          "contrats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Contrat"
            }
          },
          "dureeExperience": {
            "$ref": "#/components/schemas/DureeExperience"
          },
          "dureesHebdo": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DureeHebdo"
            }
          },
          "mobiliteHabitation": {
            "$ref": "#/components/schemas/MobiliteHabitation"
          },
          "mobilites": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Mobilite"
            }
          },
          "rome": {
            "$ref": "#/components/schemas/Rome"
          },
          "salaire": {
            "$ref": "#/components/schemas/Salaire"
          },
          "typologieEmploi": {
            "$ref": "#/components/schemas/TypologieEmploi"
          },
          "typeCrefFranchise": {
            "type": "boolean",
            "description": "Indique si le CREF concerne une franchise"
          },
          "typeCrefReprise": {
            "type": "boolean",
            "description": "Indique si le CREF concerne une reprise"
          },
          "typeCrefCreation": {
            "type": "boolean",
            "description": "Indique si le CREF concerne une création"
          }
        }
      },
      "Appellation": {
        "type": "object",
        "properties": {
          "libelle": {
            "type": "string",
            "description": "Libellé de l'appellation précise du référentiel ROME"
          },
          "code": {
            "type": "string",
            "description": "Code de l'appellation précise du référentiel ROME"
          }
        }
      },
      "Contrat": {
        "type": "object",
        "properties": {
          "critereOre": {
            "type": "boolean",
            "description": "Critère ORE"
          },
          "priorite": {
            "type": "integer",
            "description": "Critère recherché en priorité"
          },
          "type": {
            "$ref": "#/components/schemas/TypeContrat"
          }
        }
      },
      "TypeContrat": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Code du type de contrat"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé du type de contrat"
          },
          "libelleLong": {
            "type": "string",
            "description": "Libellé long du type de contrat"
          }
        }
      },
      "DureeExperience": {
        "type": "object",
        "properties": {
          "valeur": {
            "type": "integer",
            "description": "Valeur de l'expérience"
          },
          "unite": {
            "$ref": "#/components/schemas/UniteExperience"
