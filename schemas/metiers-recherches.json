        }
      },
      "UniteExperience": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Code de l'unité d'expérience"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé de l'unité d'expérience"
          }
