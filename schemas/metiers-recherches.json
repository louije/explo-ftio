          "code": {
            "type": "string",
            "description": "Code du lieu"
          },
          "codeDepartement": {
            "type": "string",
            "description": "Code du département"
          },
          "codePostal": {
            "type": "string",
            "description": "Code postal"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé du lieu"
          },
          "type": {
            "$ref": "#/components/schemas/TypeLieu"
          }
        }
      },
      "TypeLieu": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "Code du type de lieu"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé du type de lieu"
          }
        }
      },
      "Rome": {
        "type": "object",
        "properties": {
          "libelle": {
            "type": "string",
            "description": "Libellé de la famille ROME"
          },
          "code": {
            "type": "string",
            "description": "Code de la famille ROME"
          }
        }
      },
      "Salaire": {
        "type": "object",
        "properties": {
          "remuneration": {
            "type": "number",
            "description": "Montant de la rémunération",
            "format": "double"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé de la rémunération"
          },
          "code": {
            "type": "string",
            "description": "Code de la rémunération"
          }
        }
      },
      "TypologieEmploi": {
        "type": "object",
        "properties": {
          "libelle": {
            "type": "string",
            "description": "Libellé de la typologie d'emploi"
          },
          "code": {
            "type": "string",
            "description": "Code de la typologie d'emploi"
          }
        }
      }
    }
  }
}