            "type": "string",
            "description": "Code du temps de travail"
          },
          "libelle": {
            "type": "string",
            "description": "Libellé du temps de travail"
          },
          "max": {
            "type": "integer",
            "description": "Temps de travail maximum (en heures)"
          },
          "min": {
            "type": "integer",
            "description": "Temps de travail minimum (en heures)"
          }
        }
      },
      "MobiliteHabitation": {
