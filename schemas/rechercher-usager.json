  "info": {
    "version": "2.0",
    "title": "Rechercher usager",
    "description": "Ce service permet de rechercher un usager connu du réseau pour l'emploi en fonction de critères discriminants et le cas échéant de récupérer un jeton usager ainsi que le numéro France Travail permettant d'accéder à d'autres API\r\n\r\n**Scope :** `api_rechercher-usagerv2`,`rechercheusager`,`profil_accedant`\r\n\r\n**Royaume :** `/agent`"
  },
  "servers": [
    {
      "url": "https://api.francetravail.io/partenaire/rechercher-usager/v2"
    }
  ],
  "paths": {
    "/usagers/par-datenaissance-et-nir": {
      "post": {
        "tags": [
          "Par date de naissance et NIR"
        ],
        "summary": "Rechercher un usager par date de naissance et numéro de sécurité sociale (NIR)",
        "description": "A partir de la saisie de la date de naissance et du NIR, cette API fournit un jeton usager crypté dès lors que l’individu est connu de France Travail. Ce jeton va permettre la consommation d’autres services API nécessitant un jeton usager en clé d’appel.",
        "operationId": "RechercherUsagerParDateNaissanceEtNir",
        "parameters": [
          {
            "name": "pa-nom-agent",
            "in": "header",
            "required": true,
            "description": "**Attribut obligatoire en mode Client Credentials**.\r\n\r\n Nom de l'agent partenaire à l'origine de l'appel. Le caractère spécial pipe/barre verticale ' | ' est interdit.\r\n\r\nDans le cadre d'un appel depuis un traitement de type batch, renseigner un nom logique de batch.",
            "schema": {
              "type": "string",
              "example": "Martin"
            }
          },
          {
            "name": "pa-prenom-agent",
            "in": "header",
            "required": true,
            "description": "**Attribut obligatoire en mode Client Credentials**.\r\n\r\n Prénom de l'agent partenaire à l'origine de l'appel. Le caractère spécial pipe/barre verticale ' | ' est interdit.\r\n\r\nDans le cadre d'un appel depuis un traitement de type batch, renseigner un nom logique de batch.",
            "schema": {
              "type": "string",
              "example": "Henri"
            }
          },
          {
            "name": "pa-identifiant-agent",
            "in": "header",
            "required": true,
            "description": "**Attribut obligatoire en mode Client Credentials**.\r\n\r\n Identifiant de l'agent partenaire à l'origine de l'appel. Le caractère spécial pipe/barre verticale ' | ' est interdit.\r\n\r\nDans le cadre d'un appel depuis un traitement de type batch, renseigner un nom logique de batch.",
            "schema": {
              "type": "string",
              "example": "IdentifiantAgent"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json; charset=utf-8": {
              "schema": {
                "$ref": "#/components/schemas/ParDateNaissanceEtNirDTO"
              },
              "examples": {
                "Exemple d'appel": {
                  "value": {
                    "dateNaissance": "1972-06-01",
                    "nir": "1720678355011"
                  }
                }
              }
            }
          },
          "description": ""
        },
        "responses": {
          "200": {
            "description": "Retourne les informations de l'usager trouvé",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/ResultatDTO"
                },
                "examples": {
                  "Usager trouvé": {
                    "value": {
                      "codeRetour": "S001",
                      "message": "Usager trouvé",
                      "topIdentiteCertifiee": "O",
                      "jetonUsager": "",
                      "numeroFranceTravail": "10107641246"
                    }
                  },
                  "Usager trouvé non certifié": {
                    "value": {
                      "codeRetour": "S001",
                      "message": "Usager trouvé",
                      "topIdentiteCertifiee": "N",
                      "jetonUsager": "",
                      "numeroFranceTravail": "10107641246"
                    }
                  },
                  "Aucun usager trouvé": {
                    "value": {
                      "codeRetour": "S002",
                      "message": "Aucun usager trouvé",
                      "topIdentiteCertifiee": null,
                      "jetonUsager": null,
                      "numeroFranceTravail": null
                    }
                  },
                  "Plus d'un usager trouvé": {
                    "value": {
                      "codeRetour": "S003",
                      "message": "Plusieurs usagers trouvés",
                      "topIdentiteCertifiee": null,
                      "jetonUsager": null,
                      "numeroFranceTravail": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Le ou les paramètres fournis en entrée sont erronés ou absents",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Resultat400DTO"
                },
                "examples": {
                  "Erreur de validation": {
                    "value": {
                      "codeRetour": "R997",
                      "message": "Une erreur de validation s'est produite",
                      "jetonUsager": null
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "L'accès à cette ressource n'est pas autorisé",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Resultat403DTO"
                },
                "examples": {
                  "Accès non autorisé": {
                    "value": {
                      "codeRetour": "R001",
                      "message": "Accès non autorisé",
                      "jetonUsager": null
                    }
                  },
                  "L'usager et l'accédant ne sont pas dans la même structure": {
                    "value": {
                      "codeRetour": "R002",
                      "message": "L'usager n'est pas rattaché à la structure de l'accédant",
                      "jetonUsager": null
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Service en erreur",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Resultat500DTO"
                },
                "examples": {
                  "Service en erreur": {
                    "value": {
                      "codeRetour": "R998",
                      "message": "Un service a répondu en erreur",
                      "jetonUsager": null
                    }
                  }
                }
              }
            }
          },
          "503": {
            "description": "Le service est actuellement indisponible",
            "content": {
              "application/json; charset=utf-8": {
                "schema": {
                  "$ref": "#/components/schemas/Resultat503DTO"
                },
                "examples": {
                  "Service indisponible": {
                    "value": {
                      "codeRetour": "R999",
                      "message": "Service indisponible, veuillez réessayer ultérieurement",
                      "jetonUsager": null
                    }
                  }
                }
              }
            }
          }
        },
        "servers": [
          {
            "url": "https://api.francetravail.io/partenaire/rechercher-usager/v2",
            "description": "PROD"
          }
        ],
